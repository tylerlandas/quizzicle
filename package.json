{
  "name": "quizzicle-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "seed": "cd backend && npm run seed",
    "test:a11y": "playwright test tests/accessibility.spec.ts",
    "test:a11y:ui": "playwright test tests/accessibility.spec.ts --ui",
    "test:ui": "playwright test tests/ui.spec.ts",
    "test:ui:ui": "playwright test tests/ui.spec.ts --ui",
    "test": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2"
  }
}
